# Configuração da Squad de Agentes Inteligentes
# Copie este arquivo para .env e preencha com suas credenciais

# =============================================================================
# GOOGLE GEMINI API (OBRIGATÓRIO)
# =============================================================================
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# =============================================================================
# JIRA (OPCIONAL - apenas se quiser integração real com Jira)
# =============================================================================
# URL da sua instância Jira (formato: https://sua-empresa.atlassian.net)
JIRA_URL=https://sua-empresa.atlassian.net

# Email usado para login no Jira
JIRA_EMAIL=seu-email@exemplo.com

# Token de API do Jira
# Obtenha em: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_KEY=seu_token_jira_aqui

# =============================================================================
# PROXY (OPCIONAL - apenas para ambientes corporativos)
# =============================================================================
# Configuração de proxy HTTP (se necessário)
# HTTP_PROXY=http://proxy.empresa.com:8080
# HTTPS_PROXY=https://proxy.empresa.com:8080

# =============================================================================
# NOTAS:
# =============================================================================
# - GEMINI_API_KEY é OBRIGATÓRIO para o funcionamento do sistema
# - JIRA_* são OPCIONAIS - você pode testar localmente sem Jira
# - Para testar sem Jira, desmarque "Usar integração com Jira" na interface web
# - NUNCA commite este arquivo .env com suas credenciais reais
# - Este arquivo .env.example serve apenas como template
